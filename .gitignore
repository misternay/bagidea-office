# Godot editor/import cache
godot/.godot/

# Rust build artifacts
shell/target/

# Personal Claude Code permission overrides (per-machine)
.claude/settings.local.json

# Runtime artifacts
daemon/journal.jsonl
daemon/registry.json
daemon/sessions.json
daemon/map_bg.png
daemon/mcp_*.json
daemon/jobs.json
daemon/notes.json
daemon/calendar.json
daemon/projects.json

# Adapter session workspace (keep only the permission-hook config)
workspace/*
!workspace/.claude/
workspace/.claude/*
!workspace/.claude/settings.json

# Licensed third-party character art — download from itch.io (see README),
# not redistributable in this repo. The game falls back to procedural
# sprites when these are missing.
godot/assets/characters/
godot/assets/scifi/
_assets_tmp/
*.zip

# Third-party asset archives
*.rar
*.7z
godot/assets/env/
godot/assets/decor/

_shots/
shots/
# dev render harnesses + preview captures (grid rewrite)
godot/_*.gd
_grid_*.png
_*.png
godot/assets/pixelfx/
godot/assets/sounds/

# Working art files at repo root (untracked until the owner decides)
CharacterBase*

# Plugin runtime data + user-dropped media
plugins/*/data/
plugins/music/tracks/
daemon/layout.json
daemon/i18n/
dist/
daemon/presets.json
daemon/assets.json
daemon/stats.json
